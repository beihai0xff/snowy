# ============================================================
# Snowy Web — Multi-stage Dockerfile
# 构建前端静态产物并用 Nginx 提供服务
#
# 用法:
#   docker build -f deployments/docker/Dockerfile.web -t snowy-web .
# ============================================================

# ── Stage 1: Build ──────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

# 复制 package files，利用 Docker layer cache
COPY web/snowy-web/package.json web/snowy-web/package-lock.json ./

RUN npm ci

# 复制前端源码
COPY web/snowy-web/ .

# 构建静态产物
RUN npx next build

# ── Stage 2: Nginx Runtime ──────────────────────────────────
FROM nginx:1.27-alpine

# 复制自定义 Nginx 配置
COPY deployments/docker/nginx.conf /etc/nginx/nginx.conf

# 复制构建产物
COPY --from=builder /app/out /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
