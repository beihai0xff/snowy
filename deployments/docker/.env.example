# Snowy — Docker Compose 环境变量示例
# 复制此文件为 .env 并按需修改

# ── PostgreSQL ──
POSTGRES_USER=snowy
POSTGRES_PASSWORD=snowy_secret
POSTGRES_DB=snowy

# ── Redis ──
REDIS_MAX_MEMORY=256mb

# ── MinIO ──
MINIO_ROOT_USER=snowy_admin
MINIO_ROOT_PASSWORD=snowy_minio_secret

# ── Grafana ──
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=snowy_grafana

